{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "Python"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "pip install --no-cache-dir -r requirements.txt && python main.py"
  }
}