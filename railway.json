{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "PYTHON",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "pip install --no-cache-dir -r requirements.txt && python fayan_main.py server"
  }
}